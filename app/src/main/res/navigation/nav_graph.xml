<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.personal.endpointmobile.presentation.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_orderResultFragment"
            app:destination="@id/orderResultFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.personal.endpointmobile.presentation.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_orderResultFragment"
            app:destination="@id/orderResultFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.personal.endpointmobile.presentation.ui.home.SearchFragment"
        android:label="ค้นหา"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_searchFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/searchFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_searchFragment_to_searchResultFragment"
            app:destination="@id/searchResultFragment" />
        <action
            android:id="@+id/action_searchFragment_to_ordersFragment"
            app:destination="@id/ordersFragment" />
        <action
            android:id="@+id/action_searchFragment_to_orderResultFragment"
            app:destination="@id/orderResultFragment" />
    </fragment>

    <fragment
        android:id="@+id/ordersFragment"
        android:name="com.personal.endpointmobile.presentation.ui.home.OrdersFragment"
        android:label="Orders"
        tools:layout="@layout/fragment_orders">
        <action
            android:id="@+id/action_ordersFragment_to_searchFragment"
            app:destination="@id/searchFragment"
            app:popUpTo="@id/searchFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_ordersFragment_to_orderResultFragment"
            app:destination="@id/orderResultFragment" />
    </fragment>

    <fragment
        android:id="@+id/orderResultFragment"
        android:name="com.personal.endpointmobile.presentation.ui.home.OrderResultFragment"
        android:label="รายการ Order"
        tools:layout="@layout/fragment_order_result">
        <action
            android:id="@+id/action_orderResultFragment_to_ordersFragment"
            app:destination="@id/ordersFragment" />
        <action
            android:id="@+id/action_orderResultFragment_to_searchFragment"
            app:destination="@id/searchFragment" />
        <action
            android:id="@+id/action_orderResultFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/orderResultFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/searchResultFragment"
        android:name="com.personal.endpointmobile.presentation.ui.home.SearchResultFragment"
        android:label="ผลการค้นหา"
        tools:layout="@layout/fragment_search_result">
        <argument android:name="name" app:argType="string" android:defaultValue="" />
        <argument android:name="province" app:argType="string" android:defaultValue="" />
        <argument android:name="district" app:argType="string" android:defaultValue="" />
        <argument android:name="subDistrict" app:argType="string" android:defaultValue="" />
        <argument android:name="date" app:argType="string" android:defaultValue="" />
        <action
            android:id="@+id/action_searchResultFragment_to_searchFragment"
            app:destination="@id/searchFragment"
            app:popUpTo="@id/searchFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_searchResultFragment_to_ordersFragment"
            app:destination="@id/ordersFragment" />
        <action
            android:id="@+id/action_searchResultFragment_to_orderResultFragment"
            app:destination="@id/orderResultFragment" />
    </fragment>

</navigation>
